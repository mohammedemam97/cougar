/*
  X-Content-Type-Options: nosniff

/
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0

/*.html
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0

/service-worker.js
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0

/manifest.webmanifest
  Cache-Control: no-cache, max-age=0

/assets/css/*
  Cache-Control: no-cache, max-age=0

/assets/js/*
  Cache-Control: no-cache, max-age=0

/assets/images/*
  Cache-Control: public, max-age=86400

/assets/icons/*
  Cache-Control: public, max-age=86400
